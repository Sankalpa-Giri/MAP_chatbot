<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.AudiBot" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Transparent bars for all phones -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Light icons -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

    </style>

    <style name="Theme.AudiBot" parent="Base.Theme.AudiBot" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sky_blue</item>
        <item name="postSplashScreenTheme">@style/Theme.AudiBot</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/audibot_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">3000</item>
    </style>

</resources>
